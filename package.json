{
  "name": "mimo-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for MiMo multimodal capabilities (image, audio, video understanding, ASR, TTS)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mimo-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:axios --external:zod",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "mimo",
    "multimodal",
    "asr",
    "tts"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.7.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
